# =============================================================================
# younest — 환경변수 템플릿
# .env.local에 복사해서 사용 (.env.local은 .gitignore에 포함, 절대 커밋 금지)
# =============================================================================

# ----- Next.js 앱 URL -----
# 클라이언트/서버 양쪽에서 사용 (로그아웃 리다이렉트 등)
# production에서는 https://yourdomain.com 으로 교체
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ----- Supabase -----
# 대시보드 → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# ⚠️ service_role은 절대 클라이언트 노출 금지. 서버 컴포넌트/Route Handler에서만.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# 마이그레이션 푸시용 (Project Settings → Database → Connection string)
SUPABASE_DB_URL=postgresql://postgres:[password]@db.xxx.supabase.co:5432/postgres

# ----- 카카오 OAuth (M1부터 필요) -----
# https://developers.kakao.com/console/app → 앱 등록 → REST API 키
KAKAO_REST_API_KEY=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=http://localhost:3000/api/auth/kakao/callback

# ----- 어드민 (M1) -----
# 본인 카카오 ID (콤마 구분). 이 ID로 로그인 시 자동으로 is_admin=true.
ADMIN_KAKAO_IDS=

# ----- 세션 (M1) -----
# `openssl rand -base64 32`로 생성한 무작위 문자열
SESSION_SECRET=
